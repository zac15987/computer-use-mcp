{
  "name": "zpit-desktop-mcp",
  "version": "1.1.0",
  "description": "Desktop-control MCP server for zpit (https://github.com/zac15987/zpit). Fork of @zavora-ai/computer-use-mcp with Windows AUMID launch support and zpit-specific fixes. Cross-platform (macOS + Windows), backed by Rust NAPI.",
  "author": "Chih Hao Yeh <zac15987@gmail.com>",
  "contributors": [
    "James Karanja Maina <james@zavora.ai> (https://zavora.ai) (original @zavora-ai/computer-use-mcp author)"
  ],
  "forkOf": "@zavora-ai/computer-use-mcp@6.1.0",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "os": [
    "darwin",
    "win32"
  ],
  "bin": {
    "zpit-desktop-mcp": "dist/server.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zac15987/computer-use-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/zac15987/zpit/issues"
  },
  "homepage": "https://github.com/zac15987/zpit#desktop-agent",
  "exports": {
    ".": {
      "import": "./dist/server.js",
      "types": "./dist/server.d.ts"
    },
    "./client": {
      "import": "./dist/client.js",
      "types": "./dist/client.d.ts"
    },
    "./server": {
      "import": "./dist/server.js",
      "types": "./dist/server.d.ts"
    }
  },
  "files": [
    "dist/server.js",
    "dist/server.d.ts",
    "dist/entrypoint.js",
    "dist/entrypoint.d.ts",
    "dist/aumid.js",
    "dist/aumid.d.ts",
    "dist/client.js",
    "dist/client.d.ts",
    "dist/session.js",
    "dist/session.d.ts",
    "dist/native.js",
    "dist/native.d.ts",
    "computer-use-napi.node",
    "computer-use-napi.darwin-arm64.node",
    "computer-use-napi.darwin-x64.node",
    "computer-use-napi.win32-x64.node",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build:native": "node scripts/build-native.mjs",
    "build:ts": "tsc",
    "build": "npm run build:native && npm run build:ts",
    "test": "npm run build:ts && node --test test/*.test.mjs",
    "smoke": "npm run build && node scripts/test-v5-smoke.mjs",
    "prepublishOnly": "npm run build",
    "server": "tsx src/server.ts",
    "demo": "tsx examples/demo.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.23.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "fast-check": "^4.7.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
